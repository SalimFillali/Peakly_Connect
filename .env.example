# ================================================================
# PEAKLY — Variables d'environnement
# Copier ce fichier en .env.local pour le développement
# NE JAMAIS committer .env.local dans git
# ================================================================

# ── Supabase ──────────────────────────────────────────────────
# Disponibles dans Supabase Dashboard > Settings > API
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...votre_anon_key
SUPABASE_SERVICE_KEY=eyJhbGci...votre_service_role_key (côté serveur uniquement)

# ── Stripe ────────────────────────────────────────────────────
# Disponibles dans Stripe Dashboard > Developers > API keys
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs des prix Stripe (créer dans Stripe Dashboard > Products)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_LABEL_MONTHLY=price_...
STRIPE_PRICE_LABEL_YEARLY=price_...

# ── Application ───────────────────────────────────────────────
APP_URL=https://peakly.fr
APP_ENV=production  # development | staging | production

# ── Email (optionnel — utiliser Supabase SMTP ou Resend) ──────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@peakly.fr

# ── Analytics ─────────────────────────────────────────────────
PLAUSIBLE_DOMAIN=peakly.fr

# ── Sécurité ─────────────────────────────────────────────────
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire
RATE_LIMIT_MAX=100       # requêtes max par fenêtre
RATE_LIMIT_WINDOW=60000  # fenêtre en ms (60s)
